generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id Int @id @default(autoincrement())
  firstName String
  lastName String
  email String @unique
  username String @unique
  password String
  avatarUrl String?
  createdAt DateTime @default(now())
  posts Post[]
  requesterUser FriendShip[] @relation("RequesterUser")
  receiverUser FriendShip[] @relation("ReceiverUser")
  comment Comment[] @relation("UserComment")
  postLike PostLike[] @relation("UserLikeFromPost")
  commentLike CommentLike[] @relation("UserLikeFromComment")
  notification Notification[] @relation("Notification")
  chat ChatParticipants[] @relation("Chat")
  messages Messages[] @relation("Messages")
}

model Post {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  content String?
  imageUrl String?
  createdAt DateTime @default(now())
  comment Comment[] @relation("PostComment")
  like PostLike[] @relation("PostLike")
}

model FriendShip {
  id Int @id @default(autoincrement())
  requesterId Int
  requesterUser User @relation("RequesterUser", fields: [requesterId], references: [id])
  receiverId Int
  receiverUser User @relation("ReceiverUser", fields: [receiverId], references: [id])
  status STATUS @default(pending)
  createdAt DateTime @default(now())
  @@unique([requesterId, receiverId])
}

enum STATUS {
  pending
  accepted
  rejected
}

model Comment {
  id Int @id @default(autoincrement())
  postId Int
  post Post @relation("PostComment", fields: [postId], references: [id])
  userId Int
  user User @relation("UserComment", fields: [userId], references: [id])
  content String
  parentCommentId Int?
  createdAt DateTime @default(now())
  like CommentLike[]
}

model PostLike {
  id Int @id @default(autoincrement())
  postId Int
  post Post @relation("PostLike", fields: [postId], references: [id], onDelete: Cascade)
  userId Int
  user User @relation("UserLikeFromPost", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model CommentLike {
  id Int @id @default(autoincrement())
  commentId Int
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId Int
  user User @relation("UserLikeFromComment", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
}

model Notification {
  id Int @id @default(autoincrement())
  userId Int 
  user User @relation("Notification", fields: [userId], references: [id])
  type NotificationTypes
  entityId Int
  isRead Boolean
  createdAt DateTime @default(now())
}

enum NotificationTypes {
  inviteToFriend
  likeToPost
  likeToComment
  createComment
  acceptInviteToFriend
}

model Chat {
  id Int @id @default(autoincrement())
  createdAt DateTime @default(now())
  participants ChatParticipants[] @relation("Paricipants")
  messages Messages[] @relation("Messages")
}

model ChatParticipants {
  chatId Int
  chat Chat @relation("Paricipants",fields: [chatId], references: [id], onDelete: Cascade)
  userId Int
  user User @relation("Chat", fields: [userId], references: [id])
  @@id([chatId, userId])
}

model Messages {
  id Int @id @default(autoincrement())
  chatId Int
  chat Chat @relation("Messages", fields: [chatId], references: [id], onDelete: Cascade)
  senderId Int
  sender User @relation("Messages", fields: [senderId], references: [id])
  content String
  createdAt DateTime @default(now())
}