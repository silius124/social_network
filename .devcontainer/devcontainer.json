{
  "name": "Social Network (NestJS + Prisma + Postgres)",
  "dockerComposeFile": "./backend/docker-compose.yml", // или "./backend/docker-compose.yml"
  "service": "backend",
  "workspaceFolder": "/app",
  "shutdownAction": "stopCompose",
  "postCreateCommand": "npm install && npx prisma generate",
  "forwardPorts": [3000, 5432],
  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}
